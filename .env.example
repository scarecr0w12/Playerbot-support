# Discord Bot Token — get one at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ---------------------------------------------------------------------------
# LLM Connection (env-only — these are NOT stored in the database)
# ---------------------------------------------------------------------------
# For OpenAI:       https://api.openai.com/v1
# For Ollama:       http://localhost:11434/v1
# For LM Studio:    http://localhost:1234/v1
# For vLLM:         http://localhost:8000/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here

# ---------------------------------------------------------------------------
# LLM Behaviour Defaults (fallback values when a guild has no DB override)
# All of these are overridable per-guild at runtime via /assistant commands.
# Once set via /assistant, the DB value takes priority over these.
# ---------------------------------------------------------------------------
LLM_MODEL=gpt-3.5-turbo

# System prompt — supports placeholders: {botname} {server} {members}
# {username} {displayname} {roles} {channelname} {timestamp} {date} {time} {user}
SYSTEM_PROMPT=You are a helpful support assistant. Answer questions clearly and concisely. If you don't know the answer, say so honestly.

MAX_HISTORY_TURNS=20
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024
# EMBEDDING_MODEL=text-embedding-3-small
# IMAGE_MODEL=dall-e-3

# ---------------------------------------------------------------------------
# Moderation
# ---------------------------------------------------------------------------
# Default timeout duration in minutes when using /mute without specifying
DEFAULT_MUTE_DURATION_MINUTES=10

# Number of warnings before an automatic action is taken
MAX_WARNINGS_BEFORE_ACTION=3

# Action to take when warning threshold is exceeded: mute | kick | ban
WARNING_ACTION=mute

# ---------------------------------------------------------------------------
# Auto-Moderation
# ---------------------------------------------------------------------------
# Messages within AUTOMOD_SPAM_INTERVAL seconds that trigger spam detection
AUTOMOD_SPAM_THRESHOLD=5
AUTOMOD_SPAM_INTERVAL=5

# ---------------------------------------------------------------------------
# Economy
# ---------------------------------------------------------------------------
# Credits awarded per /payday (configurable per-guild via /econset)
# DEFAULT_PAYDAY_AMOUNT=100
# DEFAULT_PAYDAY_COOLDOWN_HOURS=12
# DEFAULT_CURRENCY_NAME=credits
